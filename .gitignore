
###############################################################################
# .gitignore
#
# This file tells Git which files and folders should NOT be tracked in the repo.
#
# For this project, we want to commit source code, templates, static source files,
# documentation, and safe example config files.
#
# We do NOT want to commit:
# - secret environment variables
# - local Python virtual environments
# - installed dependencies
# - generated cache files
# - local databases
# - local media uploads
# - generated production static files
# - editor/OS-specific files
#
# Important:
# Never commit real passwords, API keys, database URLs, Supabase keys, or Django
# SECRET_KEY values.
###############################################################################

###############################################################################
# Environment Variables and Secrets
#
# Keep real secrets local.
# Commit .env.example only, with placeholder values.
###############################################################################

.env
.env.*
!.env.example

###############################################################################
# Python Virtual Environments
#
# These folders store locally installed Python packages.
# Recreate them with:
#   python -m venv venv
#   pip install -r requirements.txt
###############################################################################

venv/
.venv/
env/

###############################################################################
# Python Cache Files
#
# Python creates these automatically.
###############################################################################

__pycache__/
*.py[cod]
*.pyo
*.pyd
*$py.class

###############################################################################
# Python Build and Package Files
#
# These are generated when packaging or building Python projects.
###############################################################################

build/
dist/
*.egg-info/
.eggs/
*.egg

###############################################################################
# Django Local Development Files
#
# db.sqlite3 is ignored in case someone temporarily uses SQLite locally.
# media/ is ignored because uploaded files should not be committed.
# staticfiles/ is generated by collectstatic for deployment.
###############################################################################

db.sqlite3
db.sqlite3-journal
media/
staticfiles/

###############################################################################
# Django Migrations
#
# Migration files SHOULD usually be committed because they track database schema
# changes for the whole team.
#
# Do not ignore migrations unless the team specifically decides otherwise.
###############################################################################

# apps/*/migrations/
# !apps/*/migrations/__init__.py

###############################################################################
# Testing and Coverage
#
# These files are generated by test and coverage tools.
###############################################################################

.pytest_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml

###############################################################################
# Formatting and Linting Caches
#
# These are generated by tools like Ruff, Black, MyPy, or Pyright.
###############################################################################

.ruff_cache/
.mypy_cache/
.pytype/

###############################################################################
# Node.js Dependencies
#
# node_modules/ is installed locally with:
#   npm install
#
# It is large and should never be committed.
###############################################################################

node_modules/

###############################################################################
# npm Logs and Cache
#
# These are generated by npm during installs or errors.
###############################################################################

npm-debug.log*
.npm/

###############################################################################
# Tailwind CSS Build Output
#
# If the team generates Tailwind CSS locally, this file may be rebuilt from
# static/src/input.css.
#
# Leave this commented out if the team wants to commit output.css so the project
# works immediately after cloning.
###############################################################################

# static/css/output.css

###############################################################################
# VSCode and Editor Files
#
# Ignore personal editor settings.
#
# If the team later wants shared VSCode settings, commit only specific files like:
#   .vscode/extensions.json
#   .vscode/settings.json
###############################################################################

.vscode/
.idea/

###############################################################################
# Operating System Files
#
# These are automatically created by macOS or Windows.
###############################################################################

.DS_Store
Thumbs.db
Desktop.ini

###############################################################################
# Logs and Temporary Files
#
# Local logs and temporary files should not be committed.
###############################################################################

*.log
logs/
*.tmp
*.temp
tmp/
temp/

###############################################################################
# Database Dumps and Backups
#
# Database exports may contain private or sensitive data.
###############################################################################

*.sql
*.dump
*.backup
*.bak
