###############################################################################
# .env.example
#
# This file is a GUIDE for what environment variables the project may need.
#
# IMPORTANT:
# - This file should be committed to GitHub.
# - This file should NOT contain real passwords, API keys, tokens, or secrets.
# - This file should NOT be added to .gitignore.
# - This file should only contain placeholder/example values.
#
# Why this file exists:
# Developers need to know which environment variables are required to run the
# project locally. Instead of sharing a real .env file, we commit this safe
# example file so everyone knows what values they may eventually need.
#
# Each developer should create their own private .env file on their computer.
# The real .env file should be ignored by Git and should never be committed.
#
# How to use this file:
#
# 1. Copy this file and rename the copy to .env
#
#    macOS:
#      cp .env.example .env
#
#    Windows PowerShell:
#      Copy-Item .env.example .env
#
# 2. Keep .env private.
#    Do not commit it.
#    Do not screenshot it.
#    Do not paste it into Discord, Slack, email, or GitHub issues.
#
# 3. Only fill in values when the project actually needs them.
#    It is okay for some variables to stay blank at first.
#
# 4. If you are not sure what a value should be, ask the mentor/team lead.
#
# 5. If a secret is ever accidentally committed or shared publicly:
#    - Tell the mentor/team lead immediately.
#    - Rotate or regenerate the exposed secret.
#    - Update the shared secret storage location.
#    - Remove the secret from Git history if needed.
#
# Recommended ways to share real secrets safely:
#
# Best options:
# - Use a password manager with shared vaults, such as:
#   - 1Password
#   - Bitwarden
#   - Dashlane
#   - LastPass
#
# Good student/team option:
# - Use a locked file in a restricted Google Drive folder.
# - Only give access to the developers who need the values.
# - Do not make the file public.
# - Do not share the file through a public link.
# - Name the file clearly, such as:
#     Project Environment Variables - PRIVATE
#
# Better than chat, but still use carefully:
# - A private Notion page with limited access.
# - A private GitHub repository secret for deployment values.
# - Supabase team access, where each developer logs in directly instead of
#   sharing the database password repeatedly.
#
# Avoid:
# - Sending secrets in Discord messages
# - Sending secrets in plain email
# - Posting secrets in GitHub issues or pull requests
# - Committing secrets to the repository
# - Hardcoding secrets directly in Python, HTML, CSS, or JavaScript files
#
# Rule of thumb:
# If the value would be dangerous if posted publicly, it belongs in .env,
# not in the codebase.
###############################################################################


###############################################################################
# Django Core Settings
#
# These settings are used by Django when running the backend application.
###############################################################################

# Django secret key used for cryptographic signing.
# Required for Django to run.
# Generate a unique value for each environment.
# Never share the production SECRET_KEY publicly.
SECRET_KEY=replace-this-with-your-local-django-secret-key

# Debug mode controls detailed error pages.
# Use True for local development.
# Use False in production.
DEBUG=True

# Comma-separated list of allowed hosts.
# Local development usually uses localhost and 127.0.0.1.
# Production should include the deployed app domain.
ALLOWED_HOSTS=localhost,127.0.0.1,.vercel.app


###############################################################################
# Supabase PostgreSQL Database Settings
#
# Supabase provides the hosted PostgreSQL database for the project.
#
# Only fill these in when the Django app is ready to connect to Supabase.
# If the project starts with local SQLite temporarily, these can stay as
# placeholders until PostgreSQL is needed.
###############################################################################

# Database name.
# Supabase usually uses postgres as the default database name.
DATABASE_NAME=postgres

# Database username.
# Supabase commonly uses postgres as the default user.
DATABASE_USER=postgres

# Database password from the Supabase project settings.
# Do not commit the real password.
DATABASE_PASSWORD=replace-this-with-supabase-database-password

# Database host from Supabase.
# Example format:
# db.abcdefghijklmnop.supabase.co
DATABASE_HOST=replace-this-with-supabase-database-host

# PostgreSQL port.
# Default PostgreSQL port is usually 5432.
DATABASE_PORT=5432


###############################################################################
# Supabase Project API Settings
#
# These may be useful later if the app directly uses Supabase APIs.
#
# Do not fill these in unless the project actually needs them.
# For a Django-only backend using Supabase just as a PostgreSQL database,
# these may not be needed right away.
###############################################################################

# Supabase project URL.
# Example:
# https://abcdefghijklmnop.supabase.co
SUPABASE_URL=replace-this-with-supabase-project-url

# Supabase anon/public key.
# This is often safe to expose in frontend apps, but still avoid committing real
# project values unless the team has confirmed it is okay.
SUPABASE_ANON_KEY=replace-this-with-supabase-anon-key

# Supabase service role key.
# This key has elevated permissions.
# Only use it on the backend if absolutely necessary.
# Never expose this in frontend code.
# Never commit the real value.
SUPABASE_SERVICE_ROLE_KEY=replace-this-with-supabase-service-role-key


###############################################################################
# Static and Media Files
#
# Static files are CSS, JavaScript, and images included with the app.
# Media files are user-uploaded files.
###############################################################################

# URL path for static files.
STATIC_URL=/static/

# URL path for uploaded media files.
MEDIA_URL=/media/


###############################################################################
# Local Development Settings
#
# These settings can help each developer customize their local environment.
###############################################################################

# Local development server URL.
LOCAL_APP_URL=http://127.0.0.1:8000

# Optional setting for local timezone.
TIME_ZONE=America/Denver


###############################################################################
# Email Settings
#
# Only fill these in if the project adds email features such as password reset,
# contact forms, notifications, or account verification.
###############################################################################

EMAIL_HOST=
EMAIL_PORT=
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=


###############################################################################
# Deployment Settings
#
# Only fill these in when deploying the project.
###############################################################################

# Public production app URL.
PRODUCTION_APP_URL=

# Deployment platform environment name.
# Example values:
# local, staging, production
ENVIRONMENT=local


###############################################################################
# Optional API Keys
#
# Only add values here if the project eventually uses external APIs.
#
# Examples:
# - Google Maps API for maps and directions
# - Geocoding API for converting addresses to coordinates
# - Calendar API for adding events
#
# Do not create API keys until the feature actually needs them.
###############################################################################

GOOGLE_MAPS_API_KEY=
GEOCODING_API_KEY=
CALENDAR_API_KEY=